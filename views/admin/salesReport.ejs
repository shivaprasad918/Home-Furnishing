                <!-- Add this button in your HTML template -->
                <button class="btn btn-outline-success" onclick="downloadSalesReport()">Download Excel</button>


                <!-- script for downloading the sales report -->
                <script>


                    function downloadSalesReport() {
                        const table = document.getElementById('salesTableBody');
                        const rows = table.getElementsByTagName('tr');
                        const data = [];

                        for (let i = 0; i < rows.length; i++) {
                            const cells = rows[i].getElementsByTagName('td');
                            if (cells.length > 0) {
                                const rowData = {
                                    User: { name: cells[0].innerText, email: cells[2].innerText },
                                    createdAt: cells[1].innerText,
                                    totalPrice: cells[3].innerText,
                                    paymentMethod: cells[4].innerText,
                                    status: cells[5].innerText
                                };
                                data.push(rowData);
                            }
                        }

                        fetch('/admin/salesreport/download', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                            },
                            body: JSON.stringify({ orders: data }),
                        })
                            .then(response => response.blob())
                            .then(blob => {
                                const url = window.URL.createObjectURL(blob);
                                const a = document.createElement('a');
                                a.href = url;
                                a.download = 'sales_report.xlsx';
                                document.body.appendChild(a);
                                a.click();
                                a.remove();
                            })
                            .catch(error => console.error('Error downloading sales report:', error));
                    }

                </script>

                <!-- script for sales report -->
                <script>


                    function fetchSalesReport(event) {

                        const startDate = document.getElementById('startDate').value;
                        const endDate = document.getElementById('endDate').value;
                        const reportType = document.getElementById('reportType').value;

                        fetch('/admin/salesreport', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                            },
                            body: JSON.stringify({ startDate, endDate, reportType }),
                        })
                            .then(response => response.json())
                            .then(data => {
                                const tableBody = document.getElementById('salesTableBody');
                                tableBody.innerHTML = '';

                                if (data.orders.length === 0) {
                                    tableBody.innerHTML = '<tr><td colspan="6">No orders found for the selected period.</td></tr>';
                                    return;
                                }

                                data.orders.forEach(order => {
                                    const row = `
                <tr>
                    <td>${order.User ? order.User.name : 'Unknown'}</td>
                    <td>${order.createdAt}</td>
                    <td>${order.User ? order.User.email : 'Unknown'}</td>
                    <td>${order.totalPrice}</td>
                    <td>${order.paymentMethod}</td>
                    <td>${order.status}</td>
                </tr>
            `;
                                    tableBody.innerHTML += row;
                                });
                            })
                            .catch(error => console.error('Error fetching sales report:', error));
                    }


                </script>


