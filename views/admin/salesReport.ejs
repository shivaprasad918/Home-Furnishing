                <div class="row">
                    <div class="col-12 grid-margin">
                        <div class="card">
                            <div class="card-body">
                                <div class="table-responsive">
                                    <table class="table">
                                        <thead>
                                            <tr>
                                                <th>User Name</th>
                                                <th>Date</th>
                                                <th>Email</th>
                                                <th>Total</th>
                                                <th>Payment Method</th>
                                                <th>Status</th>
                                            </tr>

                                        </thead>
                                        <tbody id="salesTableBody">
                                            <!-- Iterate over all sales records -->
                                            <% orders.forEach(order=> { %>
                                                <tr>

                                                    <td>
                                                        <%= order.User.name %>
                                                    </td>
                                                    <td>
                                                        <%= order.createdAt %>
                                                    </td>
                                                    <td>
                                                        <%= order.User.email%>
                                                    </td>
                                                    <!-- Add more fields as needed -->
                                                    <td>
                                                        <%= order.totalPrice %>
                                                    </td>
                                                    <td>
                                                        <%= order.paymentMethod %>
                                                    </td>
                                                    <td>
                                                        <%= order.status %>
                                                    </td>
                                                </tr>
                                                <% }); %>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
