      <!-- category -->
      <div class="container-fluid mt-3">
        <div class="row justify-content-center">
            <div class="col-md-8">
              <div class="category mt-5 p-3">
                <h2 class="cate-title text-white font-weight-bold mb-4">Category Management</h2>
                <form id="addCategoryForm" action="/admin/category" method="POST" class="category-form" onsubmit=" return validateForm();">
                    <div class="form-group">
                        <label for="categoryLabel" class="font-weight-bold">Category </label>
                        <select class="form-control" id="categoryLabel" name="categoryLabel" required>    
                            <option value="">Select category</option>
                            <option value="Table">Table</option>
                            <option value="Seating Furniture">Seating Furniture</option>
                            <option value="Bedroom Furniture">Bedroom Furniture</option>
                            <option value="Storage Furniture">Storage Furniture</option>
                        </select>
                    </div>
                    <div class="form-group">
                        <label for="subcategory" class="font-weight-bold">Sub category</label>
                        <input class="form-control" id="subcategory" name="subcategory" required>
                        <div id="subcategoryError" class="error-message"></div> <!-- Display error message here -->
                    </div>
                    <div class="form-group">
                        <label for="categoryDescription" class="font-weight-bold">Category Description</label>
                        <textarea class="form-control" id="categoryDescription" name="categoryDescription" rows="6" required></textarea>
                        <div id="categoryDescriptionError" class="error-message"></div> <!-- Display error message here -->
                    </div>
                    <button type="submit" class="btn btn-primary">Add Category</button>
                </form>
            </div>
        
            <script>
                function validateForm() {
                    // Get form inputs
                    var categoryLabel = document.getElementById('categoryLabel').value;
                    var subcategory = document.getElementById('subcategory').value.trim();
                    var categoryDescription = document.getElementById('categoryDescription').value.trim();
                    
                    // Validation flag
                    var isValid = true;
                    
                    // Check if category is selected
                    if (categoryLabel === '') {
                        isValid = false;
                        swal("Error", "Please select a category.", "error");
                        return false; // Return false to prevent form submission
                    }
                    
                    // Check if subcategory is provided
                    if (subcategory === '') {
                        isValid = false;
                        swal("Error", "Please provide a subcategory.", "error");
                        return false; // Return false to prevent form submission
                    }
                    
                    // Check if category description is provided
                    if (categoryDescription === '') {
                        isValid = false;
                        swal("Error", "Please provide a category description.", "error");
                        return false; // Return false to prevent form submission
                    }
                    
                    // Check for white spaces
                    if (!subcategory.trim()) {
                        isValid = false;
                        swal("Error", "Subcategory cannot be empty or contain only white spaces.", "error");
                        return false; // Return false to prevent form submission
                    }
                    if (!categoryDescription.trim()) {
                        isValid = false;
                        swal("Error", "Category description cannot be empty or contain only white spaces.", "error");
                        return false; // Return false to prevent form submission
                    }
                    
                    // If the form is valid, show the success message
                    if (isValid) {
                        Swal.fire({
                            title: 'Success',
                            text: 'Category added successfully!',
                            icon: 'success',
                            confirmButtonText: 'OK'
                        }).then((result) => {
                            if (result.isConfirmed) {
                                document.getElementById('addCategoryForm').submit(); // Submit the form programmatically
                            }
                        });
                    }
        
                    // Return false to prevent the form from submitting before showing the success message
                    return false;
                }
            </script>
