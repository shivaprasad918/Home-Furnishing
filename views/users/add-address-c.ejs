<!---------------validation-->


<script>
    document.getElementById('checkout-form').addEventListener('submit', function(event) {
        let isValid = true;

        // Validate Name
        const nameField = document.getElementById('first-name');
        if (!nameField.value.trim()) {
            isValid = false;
            document.getElementById('name-error').style.display = 'block';
        } else {
            document.getElementById('name-error').style.display = 'none';
        }

        // Validate Phone Number
        const phoneField = document.getElementById('phone');
        const phonePattern = /^\d{10}$/;
        if (!phonePattern.test(phoneField.value)) {
            isValid = false;
            document.getElementById('phone-error').style.display = 'block';
        } else {
            document.getElementById('phone-error').style.display = 'none';
        }

        // Validate Building Name/House Name
        const buildingNameField = document.getElementById('company-name');
        if (!buildingNameField.value.trim()) {
            isValid = false;
            document.getElementById('buildingName-error').style.display = 'block';
        } else {
            document.getElementById('buildingName-error').style.display = 'none';
        }

        // Validate City
        const cityField = document.getElementById('city');
        if (!cityField.value.trim()) {
            isValid = false;
            document.getElementById('city-error').style.display = 'block';
        } else {
            document.getElementById('city-error').style.display = 'none';
        }

        // Validate District
        const districtField = document.getElementById('district');
        if (!districtField.value.trim()) {
            isValid = false;
            document.getElementById('district-error').style.display = 'block';
        } else {
            document.getElementById('district-error').style.display = 'none';
        }

        // Validate State
        const stateField = document.getElementById('state');
        if (!stateField.value.trim()) {
            isValid = false;
            document.getElementById('state-error').style.display = 'block';
        } else {
            document.getElementById('state-error').style.display = 'none';
        }

        // Validate Pincode
        const postcodeField = document.getElementById('postcode');
        const postcodePattern = /^\d{6}$/;
        if (!postcodePattern.test(postcodeField.value)) {
            isValid = false;
            document.getElementById('postcode-error').style.display = 'block';
        } else {
            document.getElementById('postcode-error').style.display = 'none';
        }

        if (!isValid) {
            event.preventDefault();
        }
    });
</script>
